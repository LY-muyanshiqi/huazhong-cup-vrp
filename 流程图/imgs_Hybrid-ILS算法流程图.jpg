    <rect x="50" y="35" width="30" height="20" rx="3" fill="url(#mainGrad)"/>
    <text x="90" y="50" font-family="Microsoft YaHei, Arial" font-size="12" fill="#475569">数据预处理</text>
    
    <rect x="200" y="35" width="30" height="20" rx="3" fill="url(#subGrad)"/>
    <text x="240" y="50" font-family="Microsoft YaHei, Arial" font-size="12" fill="#475569">时变评估器</text>
    
    <rect x="370" y="35" width="30" height="20" rx="3" fill="url(#gaGrad)"/>
    <text x="410" y="50" font-family="Microsoft YaHei, Arial" font-size="12" fill="#475569">遗传算法</text>
    
    <rect x="520" y="35" width="30" height="20" rx="3" fill="url(#lsGrad)"/>
    <text x="560" y="50" font-family="Microsoft YaHei, Arial" font-size="12" fill="#475569">局部搜索</text>
    
    <rect x="670" y="35" width="30" height="20" rx="3" fill="url(#endGrad)"/>
    <text x="710" y="50" font-family="Microsoft YaHei, Arial" font-size="12" fill="#475569">结果输出</text>
    
    <line x1="800" y1="45" x2="840" y2="45" stroke="#8b5cf6" stroke-width="3"/>
    <polygon points="840,45 835,40 835,50" fill="#8b5cf6"/>
    <text x="850" y="50" font-family="Microsoft YaHei, Arial" font-size="12" fill="#475569">迭代返回</text>
    
    <line x1="980" y1="45" x2="1020" y2="45" stroke="#10b981" stroke-width="3"/>
    <polygon points="1020,45 1015,40 1015,50" fill="#10b981"/>
    <text x="1030" y="50" font-family="Microsoft YaHei, Arial" font-size="12" fill="#475569">流程推进</text>
